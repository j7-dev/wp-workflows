{
	"mcpServers": {
		"serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server"
			],
			"tools": [
				"*"
			]
		},
		"postman": {
			"tools": [
				"*"
			],
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@postman/postman-mcp-server",
				"--full"
			],
			"env": {
				"POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
			}
		}
	}
}